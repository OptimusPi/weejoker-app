{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://www.seedfinder.app",
          "https://seedfinder.app",
          "https://weejoker.app",
          "https://www.weejoker.app",
          "http://localhost:3000",
          "http://localhost:3001"
        ],
        "methods": ["GET", "HEAD"],
