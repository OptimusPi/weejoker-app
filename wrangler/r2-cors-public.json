{
  "rules": [
    {
      "AllowedOrigins": [
        "*"
      ],
      "AllowedMethods": [
        "GET",
        "HEAD"
      ],
      "AllowedHeaders": [
        "*"
      ],
      "ExposeHeaders": [
        "Content-Range",
        "Accept-Ranges",
        "Content-Length",
        "ETag"
      ],
      "MaxAgeSeconds": 86400
    }
  ]
}