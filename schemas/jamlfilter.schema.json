{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://weejoker.app/schemas/jamlfilter.schema.json",
    "title": "JAML Filter Configuration",
    "description": "Schema for JAML filter queries used to search seeds in the Motely JAML ecosystem",
    "type": "object",
    "properties": {
        "must": {
            "type": "array",
            "description": "Required conditions - all must be satisfied for a seed to match",
            "items": {
                "$ref": "#/$defs/filterCondition"
            }
        },
        "should": {
            "type": "array",
            "description": "Optional scoring conditions - seeds are ranked by how many they satisfy",
            "items": {
                "$ref": "#/$defs/filterCondition"
            }
        },
        "mustNot": {
            "type": "array",
            "description": "Exclusion conditions - seeds matching any of these are excluded",
            "items": {
                "$ref": "#/$defs/filterCondition"
            }
        }
    },
    "$defs": {
        "filterCondition": {
            "type": "object",
            "description": "A single filter condition",
            "properties": {
                "joker": {
                    "type": "string",
                    "description": "Joker name to filter by",
                    "examples": [
                        "Wee Joker",
                        "Blueprint",
                        "Brainstorm",
                        "Hack",
                        "Hanging Chad"
                    ]
                },
                "soulJoker": {
                    "type": "string",
                    "description": "Legendary (soul) joker name",
                    "examples": [
                        "Perkeo",
                        "Triboulet",
                        "Yorick",
                        "Chicot",
                        "Canio"
                    ]
                },
                "voucher": {
                    "type": "string",
                    "description": "Voucher name to filter by",
                    "examples": [
                        "Telescope",
                        "Observatory",
                        "Overstock",
                        "Clearance Sale"
                    ]
                },
                "tarot": {
                    "type": "string",
                    "description": "Tarot card name",
                    "examples": [
                        "The Fool",
                        "The Magician",
                        "Strength",
                        "Death"
                    ]
                },
                "planet": {
                    "type": "string",
                    "description": "Planet card name",
                    "examples": [
                        "Mercury",
                        "Venus",
                        "Earth",
                        "Mars",
                        "Jupiter"
                    ]
                },
                "spectral": {
                    "type": "string",
                    "description": "Spectral card name",
                    "examples": [
                        "Familiar",
                        "Grim",
                        "Incantation",
                        "Talisman",
                        "Aura"
                    ]
                },
                "antes": {
                    "type": "array",
                    "description": "Ante numbers where this condition should be checked",
                    "items": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 8
                    },
                    "examples": [
                        [
                            1,
                            2
                        ],
                        [
                            1,
                            2,
                            3
                        ]
                    ]
                },
                "label": {
                    "type": "string",
                    "description": "Custom label for this condition (appears as column name in results)",
                    "pattern": "^[A-Za-z0-9_]+$",
                    "examples": [
                        "Ante1_Perkeo",
                        "Early_Blueprint"
                    ]
                },
                "count": {
                    "type": "integer",
                    "description": "Minimum count required for this condition",
                    "minimum": 1,
                    "default": 1
                },
                "shop": {
                    "type": "boolean",
                    "description": "Whether to check shop availability",
                    "default": false
                },
                "pack": {
                    "type": "string",
                    "description": "Pack type to check",
                    "enum": [
                        "Arcana",
                        "Celestial",
                        "Spectral",
                        "Standard",
                        "Buffoon",
                        "Jumbo"
                    ]
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}